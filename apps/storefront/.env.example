# Copy to .env.local for local development (never commit secrets)

# Canonical site URL (used for SEO metadataBase and Cashfree return URL)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Dev server port (Next also reads PORT; Docker/other tools often use 8080 — this app defaults dev to 3000 in package.json)
# PORT=3000

# Medusa storefront URL when backend is wired
NEXT_PUBLIC_MEDUSA_BACKEND_URL=

# Payload / Strapi URL when CMS is wired
NEXT_PUBLIC_CMS_URL=

# Razorpay publishable key (test mode for dev) — shown to the browser for Checkout
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Razorpay server keys (create Order + verify signature) — never expose to client
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Cashfree PG (server). Set CASHFREE_ENV=production for live.
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=
CASHFREE_ENV=sandbox

# Show Cashfree option on checkout when server credentials are configured (still required on server)
NEXT_PUBLIC_ENABLE_CASHFREE=0

# Show Cash on Delivery at checkout (server flag; set to 1 to enable)
NEXT_PUBLIC_ENABLE_COD=0

# Optional: load catalog from HTTPS JSON instead of data/catalog.json (CDN / object store)
# CATALOG_JSON_URL=https://cdn.example.com/antifragile/catalog.json

# Product admin portal (/admin) — use a long random token; pair with ADMIN_SESSION_SECRET in prod
ADMIN_PORTAL_TOKEN=
ADMIN_SESSION_SECRET=

# PostgreSQL for Prisma (orders + reviews). Matches docker-compose.yml: postgresql://antifragile:antifragile@localhost:5433/storefront
# From apps/storefront run: npm run db:init  (starts Docker Postgres + prisma db push)
DATABASE_URL=

# Resend — order confirmation email (server only)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Razorpay webhooks — verify x-razorpay-signature (server only)
RAZORPAY_WEBHOOK_SECRET=

# Shiprocket stub — set when you wire real shipment APIs (see lib/shiprocket.ts)
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# Disable catalog writes from API (e.g. production read-only filesystem)
# ALLOW_CATALOG_WRITE=false

# WhatsApp click-to-chat (country code + number, no +)
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Analytics (optional)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=

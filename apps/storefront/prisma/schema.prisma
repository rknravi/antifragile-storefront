generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id              String   @id @default(cuid())
  sourceOrderId   String   @unique
  status          String   @default("created")
  gateway         String
  paymentRef      String?
  razorpayOrderId String?
  customerJson    String
  shippingJson    String
  itemsJson       String
  totalsJson      String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Review {
  id          String   @id @default(cuid())
  productSlug String
  rating      Int
  title       String
  body        String
  authorName  String
  createdAt   DateTime @default(now())

  @@index([productSlug])
}

/** Points earned per order (one row per sourceOrderId). */
model LoyaltyLedger {
  id            String   @id @default(cuid())
  email         String
  sourceOrderId String   @unique
  points        Int
  orderTotal    Int
  createdAt     DateTime @default(now())

  @@index([email])
}
